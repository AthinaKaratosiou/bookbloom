<!DOCTYPE html>
<html lang="el">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>BookBloom | Δράσεις & Υλοποίηση</title>
  <meta name="description" content="Οι δράσεις υλοποίησης του BookBloom: συλλογή βιβλίων, ενημερωτική καμπάνια, σχολικό παζάρι, δωρεές και αξιοποίηση εσόδων." />

  <style>
    :root {
      --bg: #080706;
      --bg2: #15100b;
      --card: rgba(255, 248, 236, 0.09);
      --card2: rgba(255, 248, 236, 0.14);
      --text: #fff8ec;
      --muted: rgba(255, 248, 236, 0.74);
      --gold: #e7b86b;
      --gold2: #ffd990;
      --brown: #8b4f25;
      --green: #7ba05b;
      --rose: #c67a63;
      --border: rgba(231, 184, 107, 0.28);
      --shadow: 0 28px 80px rgba(0,0,0,0.38);
      --radius: 28px;
      --max: 1180px;
      --fontScale: 1;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; font-size: calc(16px * var(--fontScale)); }

    body {
      font-family: "Segoe UI", system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at 12% 8%, rgba(231, 184, 107, 0.25), transparent 28rem),
        radial-gradient(circle at 85% 0%, rgba(123, 160, 91, 0.18), transparent 27rem),
        radial-gradient(circle at 48% 86%, rgba(198, 122, 99, 0.13), transparent 32rem),
        linear-gradient(135deg, var(--bg), var(--bg2));
      line-height: 1.7;
      min-height: 100vh;
      overflow-x: hidden;
    }

    body.high-contrast {
      --bg: #000;
      --bg2: #000;
      --card: rgba(255,255,255,0.12);
      --card2: rgba(255,255,255,0.18);
      --text: #ffffff;
      --muted: #ffffff;
      --gold: #ffff00;
      --gold2: #ffff66;
      --green: #00ff88;
      --rose: #ffb3b3;
      --border: rgba(255,255,0,0.65);
    }

    a { color: inherit; text-decoration: none; }
    .container { width: min(100% - 34px, var(--max)); margin: 0 auto; }

    .glass {
      background: linear-gradient(145deg, var(--card), rgba(255,255,255,0.04));
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
      backdrop-filter: blur(18px);
    }

    header {
      position: sticky;
      top: 0;
      z-index: 1000;
      background: rgba(8, 7, 6, 0.72);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(231, 184, 107, 0.18);
    }

    .topbar {
      min-height: 78px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
      font-weight: 900;
      letter-spacing: -0.04em;
      font-size: 1.25rem;
      min-width: max-content;
    }

    .brand-mark {
      width: 48px;
      height: 48px;
      display: grid;
      place-items: center;
      border-radius: 18px;
      background: linear-gradient(145deg, var(--gold), var(--brown));
      color: #1f1308;
      box-shadow: 0 16px 36px rgba(231,184,107,0.25);
      font-size: 1.35rem;
    }

    .brand small {
      display: block;
      color: var(--muted);
      font-weight: 650;
      font-size: 0.72rem;
      letter-spacing: 0;
      margin-top: -4px;
    }

    nav ul {
      list-style: none;
      display: flex;
      align-items: center;
      gap: 7px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    nav a,
    .tool-btn {
      border: 1px solid transparent;
      background: transparent;
      color: var(--muted);
      font: inherit;
      font-weight: 750;
      padding: 9px 12px;
      border-radius: 999px;
      cursor: pointer;
      transition: 0.25s ease;
      white-space: nowrap;
    }

    nav a:hover,
    nav a.active,
    .tool-btn:hover {
      color: var(--text);
      border-color: rgba(231,184,107,0.34);
      background: rgba(231,184,107,0.11);
    }

    .tools {
      display: flex;
      align-items: center;
      gap: 7px;
      flex-wrap: wrap;
      min-width: max-content;
    }

    .menu-btn {
      display: none;
      border: 1px solid var(--border);
      background: rgba(231,184,107,0.12);
      color: var(--text);
      padding: 10px 13px;
      border-radius: 14px;
      font-weight: 850;
      cursor: pointer;
    }

    .hero {
      position: relative;
      padding: 95px 0 70px;
      min-height: 72vh;
      display: grid;
      align-items: center;
    }

    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(rgba(8,7,6,0.34), rgba(8,7,6,0.9)),
        url("https://images.unsplash.com/photo-1531482615713-2afd69097998?auto=format&fit=crop&w=1800&q=80") center/cover;
      opacity: 0.42;
      z-index: -2;
    }

    .hero::after {
      content: "";
      position: absolute;
      inset: auto 0 0 0;
      height: 150px;
      background: linear-gradient(transparent, var(--bg));
      z-index: -1;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1.05fr 0.95fr;
      gap: 40px;
      align-items: center;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 9px;
      border: 1px solid rgba(231,184,107,0.38);
      background: rgba(231,184,107,0.12);
      color: var(--gold2);
      border-radius: 999px;
      padding: 8px 14px;
      font-weight: 850;
      margin-bottom: 18px;
    }

    h1 {
      font-size: clamp(2.7rem, 7vw, 6.2rem);
      line-height: 0.92;
      letter-spacing: -0.085em;
      margin-bottom: 18px;
      text-shadow: 0 18px 60px rgba(0,0,0,0.48);
    }

    .lead {
      max-width: 760px;
      color: var(--muted);
      font-size: 1.15rem;
      margin-bottom: 28px;
    }

    .btn-row { display: flex; flex-wrap: wrap; gap: 12px; }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 9px;
      border-radius: 999px;
      padding: 13px 19px;
      font-weight: 900;
      border: 1px solid transparent;
      transition: 0.25s ease;
      cursor: pointer;
    }

    .btn-primary {
      background: linear-gradient(145deg, var(--gold), var(--brown));
      color: #1d1208;
      box-shadow: 0 20px 42px rgba(231,184,107,0.23);
    }

    .btn-secondary {
      background: rgba(255,255,255,0.08);
      border-color: var(--border);
      color: var(--text);
    }

    .btn:hover { transform: translateY(-3px); }

    .hero-card {
      border-radius: 34px;
      padding: 30px;
      position: relative;
      overflow: hidden;
    }

    .hero-card::before {
      content: "";
      position: absolute;
      right: -80px;
      top: -80px;
      width: 240px;
      height: 240px;
      border-radius: 50%;
      background: rgba(231,184,107,0.16);
    }

    .hero-card h2 {
      position: relative;
      color: var(--gold2);
      font-size: 2.1rem;
      line-height: 1;
      letter-spacing: -0.055em;
      margin-bottom: 16px;
    }

    .summary-list {
      position: relative;
      display: grid;
      gap: 12px;
    }

    .summary-list div {
      padding: 14px 15px;
      border-radius: 18px;
      background: rgba(0,0,0,0.20);
      border: 1px solid rgba(231,184,107,0.22);
      color: var(--muted);
      font-weight: 700;
    }

    section { padding: 82px 0; }

    .section-heading { max-width: 890px; margin-bottom: 34px; }

    .label {
      color: var(--gold2);
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.13em;
      font-size: 0.78rem;
      margin-bottom: 10px;
      display: block;
    }

    h2 {
      font-size: clamp(2.1rem, 4.8vw, 4rem);
      line-height: 0.98;
      letter-spacing: -0.07em;
      margin-bottom: 15px;
    }

    .section-heading p { color: var(--muted); font-size: 1.08rem; }

    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
    .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px; }
    .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }

    .card,
    .step-card {
      border-radius: var(--radius);
      padding: 25px;
      transition: 0.25s ease;
      min-height: 100%;
    }

    .card:hover,
    .step-card:hover { transform: translateY(-5px); background: var(--card2); }

    .icon {
      width: 52px;
      height: 52px;
      border-radius: 18px;
      display: grid;
      place-items: center;
      background: rgba(231,184,107,0.15);
      border: 1px solid rgba(231,184,107,0.28);
      color: var(--gold2);
      font-size: 1.5rem;
      margin-bottom: 16px;
    }

    .card h3,
    .step-card h3 {
      font-size: 1.28rem;
      letter-spacing: -0.03em;
      color: var(--gold2);
      margin-bottom: 10px;
    }

    .card p,
    .step-card p,
    .card li { color: var(--muted); }
    .card ul { padding-left: 20px; margin-top: 10px; }

    .step-number {
      width: 50px;
      height: 50px;
      display: grid;
      place-items: center;
      border-radius: 18px;
      background: linear-gradient(145deg, var(--gold), var(--brown));
      color: #1d1208;
      font-weight: 950;
      margin-bottom: 16px;
    }

    .split {
      display: grid;
      grid-template-columns: 0.9fr 1.1fr;
      gap: 30px;
      align-items: start;
    }

    .sticky-note {
      position: sticky;
      top: 105px;
      border-radius: var(--radius);
      padding: 30px;
      background: linear-gradient(145deg, rgba(231,184,107,0.18), rgba(123,160,91,0.12));
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
    }

    .timeline { display: grid; gap: 14px; }

    .timeline-item {
      display: grid;
      grid-template-columns: 62px 1fr;
      gap: 16px;
      border-radius: 24px;
      padding: 18px;
    }

    .timeline-number {
      width: 56px;
      height: 56px;
      display: grid;
      place-items: center;
      border-radius: 20px;
      background: linear-gradient(145deg, var(--gold), var(--brown));
      color: #1d1208;
      font-weight: 950;
    }

    .timeline-item h3 { color: var(--gold2); letter-spacing: -0.03em; margin-bottom: 5px; }
    .timeline-item p { color: var(--muted); }

    .highlight-band {
      border-radius: 34px;
      padding: 34px;
      background: linear-gradient(135deg, rgba(231,184,107,0.22), rgba(123,160,91,0.13));
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 22px;
      align-items: center;
    }

    .mini-list { display: grid; gap: 10px; }

    .mini-list div {
      padding: 13px 15px;
      border-radius: 16px;
      background: rgba(0,0,0,0.18);
      border: 1px solid rgba(231,184,107,0.22);
      font-weight: 800;
      color: var(--muted);
    }

    .big-quote {
      border-radius: 34px;
      padding: 34px;
      background: linear-gradient(135deg, rgba(231,184,107,0.22), rgba(123,160,91,0.13));
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
    }

    .big-quote blockquote {
      font-size: clamp(1.35rem, 3vw, 2.35rem);
      line-height: 1.12;
      letter-spacing: -0.05em;
      color: var(--gold2);
      font-weight: 900;
    }

    .big-quote p { color: var(--muted); margin-top: 14px; font-size: 1.05rem; }

    .music-status {
      position: fixed;
      left: 18px;
      bottom: 18px;
      z-index: 1500;
      max-width: calc(100% - 36px);
      border-radius: 999px;
      padding: 10px 14px;
      color: var(--text);
      background: rgba(0,0,0,0.64);
      border: 1px solid var(--border);
      backdrop-filter: blur(14px);
      font-weight: 750;
      display: none;
    }

    .music-status.show { display: block; }

    .music-player {
      position: fixed;
      right: 18px;
      bottom: 88px;
      z-index: 1550;
      width: min(360px, calc(100% - 36px));
      border: 1px solid var(--border);
      border-radius: 22px;
      background: rgba(8,7,6,0.92);
      box-shadow: var(--shadow);
      backdrop-filter: blur(18px);
      overflow: hidden;
      transform: translateY(20px);
      opacity: 0;
      pointer-events: none;
      transition: 0.25s ease;
    }

    .music-player.open { transform: translateY(0); opacity: 1; pointer-events: auto; }

    .music-player-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      padding: 12px 14px;
      color: var(--gold2);
      font-weight: 900;
      border-bottom: 1px solid rgba(231,184,107,0.18);
    }

    .music-close {
      border: 1px solid var(--border);
      background: rgba(255,255,255,0.08);
      color: var(--text);
      border-radius: 999px;
      padding: 7px 10px;
      cursor: pointer;
      font-weight: 800;
    }

    .music-frame-wrap { aspect-ratio: 16 / 9; background: #000; }
    .music-frame-wrap iframe { width: 100%; height: 100%; border: 0; display: block; }

    footer {
      padding: 42px 0;
      border-top: 1px solid rgba(231,184,107,0.18);
      background: rgba(0,0,0,0.28);
    }

    footer .container {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
      flex-wrap: wrap;
    }

    footer p { color: var(--muted); }

    .backtop {
      border: 1px solid var(--border);
      border-radius: 999px;
      padding: 10px 15px;
      color: var(--gold2);
      font-weight: 850;
    }

    @media (max-width: 1180px) {
      .topbar { flex-wrap: wrap; padding: 12px 0; }
      nav { order: 3; width: 100%; }
      nav ul { justify-content: center; }
    }

    @media (max-width: 1060px) { .grid-4 { grid-template-columns: repeat(2, 1fr); } }

    @media (max-width: 980px) {
      .hero-grid, .split, .highlight-band { grid-template-columns: 1fr; }
      .grid-3 { grid-template-columns: 1fr; }
      .grid-2 { grid-template-columns: repeat(2, 1fr); }
      .sticky-note { position: static; }
    }

    @media (max-width: 780px) {
      .topbar { align-items: flex-start; padding: 14px 0; }
      .menu-btn { display: inline-flex; }
      nav {
        position: absolute;
        left: 17px;
        right: 17px;
        top: 82px;
        width: auto;
        display: none;
        border-radius: 24px;
        padding: 14px;
        background: rgba(8,7,6,0.96);
        border: 1px solid var(--border);
        box-shadow: var(--shadow);
      }
      nav.open { display: block; }
      nav ul { flex-direction: column; align-items: stretch; }
      nav a { justify-content: center; display: flex; }
      .tools {
        position: fixed;
        right: 12px;
        bottom: 12px;
        z-index: 1600;
        background: rgba(0,0,0,0.72);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 8px;
        backdrop-filter: blur(14px);
      }
      .hero { min-height: auto; padding-top: 54px; }
      .grid-2, .grid-4 { grid-template-columns: 1fr; }
      .music-player { bottom: 92px; }
    }
  </style>
</head>

<body>
  <div id="musicStatus" class="music-status">🎵 Πάτα Music για να εμφανιστεί ο μουσικός player.</div>

  <div class="music-player" id="musicPlayer" aria-label="YouTube μουσικός player">
    <div class="music-player-header">
      <span>🎵 BookBloom Music</span>
      <button class="music-close" id="closeMusic">Κλείσιμο</button>
    </div>
    <div class="music-frame-wrap" id="musicFrameWrap"></div>
  </div>

  <header>
    <div class="container topbar">
      <a class="brand" href="index.html" aria-label="Αρχική σελίδα BookBloom">
        <span class="brand-mark">🌸</span>
        <span>BookBloom <small>Η Βιβλιοθήκη που Ανθίζει</small></span>
      </a>

      <button class="menu-btn" id="menuBtn">Μενού</button>

      <nav id="nav" aria-label="Κεντρική πλοήγηση">
        <ul>
          <li><a href="index.html">Αρχική</a></li>
          <li><a href="about.html">Η Ιδέα</a></li>
          <li><a href="framework.html">Πλαίσιο</a></li>
          <li><a href="roles.html">Ρόλοι</a></li>
          <li><a class="active" href="actions.html">Δράσεις</a></li>
          <li><a href="library.html">Βιβλιοθήκη</a></li>
          <li><a href="bloomcast.html">BloomCast</a></li>
          <li><a href="evaluation.html">Αξιολόγηση</a></li>
          <li><a href="future.html">Βιωσιμότητα</a></li>
        </ul>
      </nav>

      <div class="tools" aria-label="Εργαλεία προσβασιμότητας και μουσικής">
        <button class="tool-btn" id="fontDown">A−</button>
        <button class="tool-btn" id="fontUp">A+</button>
        <button class="tool-btn" id="contrastBtn">Contrast</button>
        <button class="tool-btn" id="musicBtn">Music</button>
      </div>
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="container hero-grid">
        <div>
          <span class="eyebrow">Συλλογή • Παζάρι • Δωρεές • Υλοποίηση</span>
          <h1>Δράσεις & Υλοποίηση</h1>
          <p class="lead">
            Το BookBloom περνά από την ιδέα στην πράξη μέσα από οργανωμένες μαθητικές δράσεις: ενημέρωση της κοινότητας, συλλογή βιβλίων, δημιουργία αφισών, σχολικό παζάρι, αξιοποίηση εσόδων και διαμόρφωση των πρώτων πόρων της βιβλιοθήκης.
          </p>
          <div class="btn-row">
            <a class="btn btn-primary" href="#steps">Δες το πλάνο δράσης</a>
            <a class="btn btn-secondary" href="library.html">Συνέχεια: Βιβλιοθήκη</a>
          </div>
        </div>

        <aside class="hero-card glass">
          <h2>Κεντρικές δράσεις</h2>
          <div class="summary-list">
            <div>📚 Συλλογή βιβλίων από μαθητές, γονείς και κοινότητα.</div>
            <div>📢 Ενημερωτική καμπάνια με αφίσες και φυλλάδια.</div>
            <div>🍪 Σχολικό παζάρι με πώληση γλυκισμάτων.</div>
            <div>🎁 Χώρος δωρεών βιβλίων κατά τη διάρκεια της δράσης.</div>
            <div>💶 Αξιοποίηση εσόδων για βιβλία, γραφική ύλη και υλικά οργάνωσης.</div>
          </div>
        </aside>
      </div>
    </section>

    <section id="steps">
      <div class="container">
        <div class="section-heading">
          <span class="label">1. Πλάνο δράσεων</span>
          <h2>Η υλοποίηση οργανώνεται σε συγκεκριμένα βήματα.</h2>
          <p>
            Η επιτυχία του BookBloom στηρίζεται στην προσεκτική προετοιμασία και στη σαφή κατανομή ευθυνών. Κάθε δράση έχει παιδαγωγικό και πρακτικό στόχο: να ενεργοποιήσει τη σχολική κοινότητα και να συγκεντρώσει τους απαραίτητους πόρους για τη βιβλιοθήκη.
          </p>
        </div>

        <div class="grid-4">
          <article class="step-card glass">
            <div class="step-number">01</div>
            <h3>Ενημέρωση μαθητών</h3>
            <p>Οι μαθητές ενημερώνονται για τον σκοπό του συνεταιρισμού, την ανάγκη δημιουργίας βιβλιοθήκης και τους τρόπους με τους οποίους μπορούν να συμμετάσχουν.</p>
          </article>

          <article class="step-card glass">
            <div class="step-number">02</div>
            <h3>Καμπάνια προβολής</h3>
            <p>Η καλλιτεχνική ομάδα και η ομάδα επικοινωνίας δημιουργούν αφίσες, φυλλάδια και ανακοινώσεις που εξηγούν τον στόχο του BookBloom.</p>
          </article>

          <article class="step-card glass">
            <div class="step-number">03</div>
            <h3>Συλλογή βιβλίων</h3>
            <p>Η σχολική κοινότητα καλείται να προσφέρει βιβλία, βοηθήματα, εγκυκλοπαίδειες ή άλλο εκπαιδευτικό υλικό κατάλληλο για τη βιβλιοθήκη.</p>
          </article>

          <article class="step-card glass">
            <div class="step-number">04</div>
            <h3>Σχολικό παζάρι</h3>
            <p>Οι μαθητές, με τη στήριξη γονέων και εκπαιδευτικών, οργανώνουν παζάρι με γλυκίσματα για τη συγκέντρωση οικονομικών πόρων.</p>
          </article>
        </div>
      </div>
    </section>

    <section id="campaign">
      <div class="container split">
        <div class="sticky-note">
          <span class="label">2. Ενημερωτική καμπάνια</span>
          <h2>Η κοινότητα πρέπει πρώτα να μάθει, για να συμμετάσχει.</h2>
          <p>
            Η επικοινωνιακή δράση είναι απαραίτητη, ώστε οι μαθητές, οι γονείς, οι εκπαιδευτικοί και οι κάτοικοι της περιοχής να κατανοήσουν ότι η βιβλιοθήκη αποτελεί συλλογικό αγαθό και όχι απλώς μια εσωτερική σχολική πρωτοβουλία.
          </p>
        </div>

        <div class="timeline">
          <article class="timeline-item glass">
            <div class="timeline-number">Α</div>
            <div>
              <h3>Αφίσες και φυλλάδια</h3>
              <p>Η καλλιτεχνική ομάδα δημιουργεί οπτικό υλικό με το όνομα BookBloom, το σύνθημα «Μια σελίδα. Μια ομάδα. Μια βιβλιοθήκη που ανθίζει.» και πρακτικές πληροφορίες συμμετοχής.</p>
            </div>
          </article>

          <article class="timeline-item glass">
            <div class="timeline-number">Β</div>
            <div>
              <h3>Διανομή σε γονείς</h3>
              <p>Τα φυλλάδια διανέμονται στους γονείς, ώστε να ενημερωθούν για τις ανάγκες της βιβλιοθήκης, τις δωρεές βιβλίων και τη συμμετοχή στο παζάρι.</p>
            </div>
          </article>

          <article class="timeline-item glass">
            <div class="timeline-number">Γ</div>
            <div>
              <h3>Αφισοκόλληση στην κοινότητα</h3>
              <p>Η δράση προβάλλεται σε καταστήματα και δημόσιους χώρους, ώστε να ενεργοποιηθεί η τοπική κοινωνία και να ενισχυθεί η συλλογή βιβλίων.</p>
            </div>
          </article>

          <article class="timeline-item glass">
            <div class="timeline-number">Δ</div>
            <div>
              <h3>Ψηφιακή ενημέρωση</h3>
              <p>Η ομάδα συγγραφέων και ο υπεύθυνος οπτικοακουστικού υλικού ενημερώνουν την ιστοσελίδα, καταγράφουν δράσεις και δημιουργούν περιεχόμενο προβολής.</p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section id="bazaar">
      <div class="container">
        <div class="highlight-band">
          <div>
            <span class="label">3. Σχολικό παζάρι</span>
            <h2>Η οικονομική δράση αποκτά παιδαγωγικό νόημα.</h2>
            <p>
              Το σχολικό παζάρι με πώληση γλυκισμάτων λειτουργεί ως βιωματική εφαρμογή βασικών οικονομικών εννοιών. Οι μαθητές δεν συγκεντρώνουν απλώς χρήματα· μαθαίνουν να οργανώνουν, να συνεργάζονται, να διαχειρίζονται πόρους και να συνδέουν την οικονομική δράση με κοινωφελή σκοπό.
            </p>
          </div>

          <div class="mini-list">
            <div>🍰 Γονείς και μαθητές συμβάλλουν με γλυκίσματα και σπιτικά προϊόντα.</div>
            <div>⏱️ Ο χώρος προετοιμάζεται τουλάχιστον μία ώρα πριν από την έναρξη.</div>
            <div>📚 Προβλέπεται ειδικός χώρος για δωρεές βιβλίων.</div>
            <div>💶 Ο ταμίας καταγράφει έσοδα και έξοδα με διαφάνεια.</div>
            <div>🔁 Η δράση μπορεί να επαναλαμβάνεται 2–3 φορές ετησίως.</div>
          </div>
        </div>
      </div>
    </section>

    <section id="resources">
      <div class="container">
        <div class="section-heading">
          <span class="label">4. Αξιοποίηση πόρων</span>
          <h2>Τα έσοδα μετατρέπονται σε εκπαιδευτική υποδομή.</h2>
          <p>
            Οι οικονομικοί πόροι που συγκεντρώνονται από το παζάρι και οι δωρεές της κοινότητας αξιοποιούνται με στόχο την πρακτική οργάνωση και τη λειτουργική αναβάθμιση της βιβλιοθήκης.
          </p>
        </div>

        <div class="grid-3">
          <article class="card glass">
            <div class="icon">📚</div>
            <h3>Αγορά βιβλίων</h3>
            <p>Προτεραιότητα δίνεται σε λογοτεχνικά βιβλία, σχολικά βοηθήματα, επιστημονικά βιβλία και υλικό που ανταποκρίνεται στις ανάγκες των μαθητών.</p>
          </article>

          <article class="card glass">
            <div class="icon">🗂️</div>
            <h3>Υλικά οργάνωσης</h3>
            <p>Αγοράζονται ετικέτες, καρτέλες δανεισμού, τετράδια καταγραφής, κουτιά ταξινόμησης και γραφική ύλη για την ορθή λειτουργία της βιβλιοθήκης.</p>
          </article>

          <article class="card glass">
            <div class="icon">🪵</div>
            <h3>Παλέτες και εξοπλισμός</h3>
            <p>Τα έσοδα μπορούν να αξιοποιηθούν για παλέτες, ράφια, μικρά έπιπλα ή υλικά που θα βοηθήσουν στη διαμόρφωση του χώρου.</p>
          </article>
        </div>
      </div>
    </section>

    <section id="action-calendar">
      <div class="container split">
        <div class="sticky-note">
          <span class="label">5. Ενδεικτική ροή υλοποίησης</span>
          <h2>Από την προετοιμασία στην πράξη.</h2>
          <p>
            Το BookBloom οργανώνεται ως διαδικασία με διακριτά στάδια. Η ύπαρξη σαφούς ροής βοηθά τους μαθητές να λειτουργούν υπεύθυνα και να βλέπουν την πρόοδο της συλλογικής τους προσπάθειας.
          </p>
        </div>

        <div class="timeline">
          <article class="timeline-item glass">
            <div class="timeline-number">1</div>
            <div><h3>Προετοιμασία</h3><p>Κατανομή ρόλων, σχεδιασμός αφισών, ενημέρωση μαθητών, γονέων και εκπαιδευτικών.</p></div>
          </article>
          <article class="timeline-item glass">
            <div class="timeline-number">2</div>
            <div><h3>Ενεργοποίηση κοινότητας</h3><p>Διανομή φυλλαδίων, αφισοκόλληση, ανακοινώσεις και πρόσκληση για δωρεές βιβλίων.</p></div>
          </article>
          <article class="timeline-item glass">
            <div class="timeline-number">3</div>
            <div><h3>Ημέρα παζαριού</h3><p>Προετοιμασία χώρου, πώληση γλυκισμάτων, καταγραφή εσόδων και συλλογή βιβλίων σε ειδικό σημείο.</p></div>
          </article>
          <article class="timeline-item glass">
            <div class="timeline-number">4</div>
            <div><h3>Αποτίμηση και αξιοποίηση</h3><p>Καταμέτρηση βιβλίων, οικονομικός απολογισμός, αγορά υλικών και σχεδιασμός επόμενης δράσης.</p></div>
          </article>
        </div>
      </div>
    </section>

    <section>
      <div class="container">
        <div class="big-quote">
          <blockquote>Οι δράσεις του BookBloom μετατρέπουν τη σχολική κοινότητα σε ενεργό δημιουργό της βιβλιοθήκης.</blockquote>
          <p>
            Κάθε αφίσα, κάθε βιβλίο, κάθε γλύκισμα και κάθε προσφορά λειτουργεί ως μέρος μιας μεγαλύτερης παιδαγωγικής διαδικασίας: οι μαθητές μαθαίνουν να σχεδιάζουν, να συνεργάζονται, να προσφέρουν και να βλέπουν το αποτέλεσμα της συλλογικής τους προσπάθειας.
          </p>
        </div>
      </div>
    </section>
  </main>

  <footer>
    <div class="container">
      <div>
        <strong>BookBloom | Δράσεις & Υλοποίηση</strong>
        <p>Μια σελίδα. Μια ομάδα. Μια βιβλιοθήκη που ανθίζει.</p>
      </div>
      <a class="backtop" href="library.html">Επόμενη σελίδα →</a>
    </div>
  </footer>

  <script>
    const root = document.documentElement;
    const nav = document.getElementById('nav');
    const menuBtn = document.getElementById('menuBtn');
    const fontDown = document.getElementById('fontDown');
    const fontUp = document.getElementById('fontUp');
    const contrastBtn = document.getElementById('contrastBtn');

    const musicBtn = document.getElementById('musicBtn');
    const musicPlayer = document.getElementById('musicPlayer');
    const musicFrameWrap = document.getElementById('musicFrameWrap');
    const closeMusic = document.getElementById('closeMusic');
    const musicStatus = document.getElementById('musicStatus');

    const youtubeMusicUrl = 'https://www.youtube.com/embed/uEKT1cYRuYs?autoplay=1&loop=1&playlist=uEKT1cYRuYs&rel=0&modestbranding=1';

    let fontScale = 1;

    menuBtn.addEventListener('click', () => {
      nav.classList.toggle('open');
    });

    document.querySelectorAll('nav a').forEach(link => {
      link.addEventListener('click', () => nav.classList.remove('open'));
    });

    fontDown.addEventListener('click', () => {
      fontScale = Math.max(0.88, fontScale - 0.06);
      root.style.setProperty('--fontScale', fontScale);
    });

    fontUp.addEventListener('click', () => {
      fontScale = Math.min(1.22, fontScale + 0.06);
      root.style.setProperty('--fontScale', fontScale);
    });

    contrastBtn.addEventListener('click', () => {
      document.body.classList.toggle('high-contrast');
    });

    const showMusicMessage = (message) => {
      musicStatus.textContent = message;
      musicStatus.classList.add('show');
      setTimeout(() => musicStatus.classList.remove('show'), 4200);
    };

    musicBtn.addEventListener('click', () => {
      musicPlayer.classList.add('open');

      if (!musicFrameWrap.querySelector('iframe')) {
        musicFrameWrap.innerHTML = `
          <iframe
            src="${youtubeMusicUrl}"
            title="BookBloom Music"
            allow="autoplay; encrypted-media"
            allowfullscreen>
          </iframe>
        `;
      }

      showMusicMessage('🎵 Ο μουσικός player άνοιξε. Αν δεν ξεκινήσει αυτόματα, πάτα play μέσα στο βίντεο.');
    });

    closeMusic.addEventListener('click', () => {
      musicPlayer.classList.remove('open');
      musicFrameWrap.innerHTML = '';
      showMusicMessage('⏸️ Η μουσική σταμάτησε.');
    });
  </script>
</body>
</html>
